# Backend runtime config
# Required: PocketBase base URL (no trailing slash)
PB_URL=http://127.0.0.1:8090

# Optional API port
PORT=3001

# Optional comma-separated CORS allowlist for browser clients
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://dashboard.michaelballin.com

# Optional timeout for PocketBase upstream calls (milliseconds)
UPSTREAM_TIMEOUT_MS=15000

# Weekly recap email (required to enable scheduled delivery)
RESEND_API_KEY=re_xxxxxxxxxx
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=replace-with-strong-password
RECAP_FROM_EMAIL=dashboard@example.com
RECAP_ADMIN_ALERT_EMAIL=alerts@example.com
