      "job-dashboard-search-strings": [
        {
          "label": "\ud83c\udfaf LinkedIn Boolean \u2014 CoS / Ops (Primary)",
          "query": "(\"chief of staff\" OR \"head of operations\" OR \"business operations\" OR \"bizops\" OR \"operations manager\" OR \"founding operations\") AND (\"startup\" OR \"early stage\" OR \"series A\" OR \"seed\")",
          "tip": "Paste into LinkedIn Jobs search bar. Filter: Date posted \u2192 Past week. Job type \u2192 Full-time."
        },
        {
          "label": "\ud83d\udd0d LinkedIn Boolean \u2014 Broader Ops",
          "query": "(\"general manager\" OR \"director of operations\" OR \"head of biz ops\" OR \"chief operating officer\" OR \"VP operations\" OR \"strategy and operations\") AND (\"startup\" OR \"early-stage\" OR \"small team\" OR \"founding team\")",
          "tip": "Use when primary search runs dry. Good for COO-lite roles at 10\u201350 person companies."
        },
        {
          "label": "\u2699\ufe0f LinkedIn Boolean \u2014 Product + Ops Hybrid",
          "query": "(\"product operations\" OR \"program manager\" OR \"product manager\" OR \"head of product\" OR \"product lead\") AND (\"operations\" OR \"startup\" OR \"seed\" OR \"series A\") NOT (\"senior\" OR \"staff\" OR \"principal\" OR \"director\")",
          "tip": "For PM/PO hybrid roles. The NOT clause filters out senior-only posts."
        },
        {
          "label": "\ud83c\udf3f LinkedIn Boolean \u2014 Maine / New England",
          "query": "(\"chief of staff\" OR \"operations manager\" OR \"business operations\" OR \"general manager\") AND (\"Maine\" OR \"Portland ME\" OR \"New Hampshire\" OR \"Vermont\" OR \"Boston\" OR \"remote\")",
          "tip": "Geo-focused. Also try filtering Location to 'Portland, Maine Area' in LinkedIn."
        },
        {
          "label": "\ud83c\udfed LinkedIn Boolean \u2014 Manufacturing / Hardware Ops",
          "query": "(\"operations manager\" OR \"head of operations\" OR \"manufacturing operations\" OR \"supply chain\" OR \"product development\") AND (\"3D printing\" OR \"composites\" OR \"hardware\" OR \"manufacturing\" OR \"marine\" OR \"outdoor\" OR \"consumer goods\") AND (\"startup\" OR \"small company\")",
          "tip": "Leverages your manufacturing startup background for hardware-adjacent roles."
        },
        {
          "label": "\ud83d\udd0e Google X-Ray Search (paste into Google)",
