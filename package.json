{
  "name": "job-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"VITE,API,PB\" -c \"green,blue,yellow\" --kill-others \"npm:dev:vite\" \"npm:dev:api\" \"npm:dev:pb\"",
    "dev:vite": "vite",
    "dev:api": "npm --prefix server run dev",
    "dev:pb": "./pocketbase/pocketbase serve --http=127.0.0.1:8090 --dir=./pocketbase/pb_data",
    "dev:frontend": "vite",
    "dev:no-pb": "concurrently --names \"VITE,API\" -c \"green,blue\" --kill-others \"npm:dev:vite\" \"npm:dev:api\"",
    "build": "VITE_APP_VERSION=$(node -p \"require('./package.json').version\") VITE_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo) vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "migrate": "bash scripts/migrate.sh",
    "schema:export": "node scripts/export-pb-schema.js",
    "seed:local": "node scripts/seed-local.js",
    "setup": "bash scripts/setup-local.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite": "^8.0.0-beta.13"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "license": "MIT",
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
