# Backend runtime config
# Required: PocketBase base URL (no trailing slash)
PB_URL=https://pocketbase.example.com

# Optional API port
PORT=3001

# Optional comma-separated CORS allowlist for browser clients
CORS_ALLOWED_ORIGINS=https://dashboard.michaelballin.com,http://localhost:5173

# Optional timeout for PocketBase upstream calls (milliseconds)
UPSTREAM_TIMEOUT_MS=15000
